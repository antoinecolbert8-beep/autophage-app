// ============================================================================
// 🚀 AUTOPHAGE SAAS - PRODUCTION SCHEMA
// SaaS d'automatisation de contenu social média avec pay-per-use
// ============================================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// 👤 USERS & AUTHENTICATION
// ============================================================================

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  name              String?
  avatar            String?
  emailVerified     DateTime?
  
  // Stripe
  stripeCustomerId  String?             @unique
  
  // Quotas & Usage
  currentPlan       Plan                @default(STARTER)
  monthlyQuota      Int                 @default(10)
  usedQuota         Int                 @default(0)
  quotaResetDate    DateTime
  
  // Relations
  subscription      Subscription?
  socialAccounts    SocialAccount[]
  videos            Video[]
  carrousels        Carrousel[]
  posts             Post[]
  usageRecords      UsageRecord[]
  invoices          Invoice[]
  apiKeys           ApiKey[]
  
  // Referral system
  referralCode      String?             @unique
  referredBy        String?
  inviter           User?               @relation("Referrals", fields: [referredBy], references: [referralCode])
  referrals         User[]              @relation("Referrals")
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([email])
  @@index([stripeCustomerId])
}

enum Plan {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

// ============================================================================
// 💳 SUBSCRIPTIONS & BILLING
// ============================================================================

model Subscription {
  id                  String               @id @default(cuid())
  userId              String               @unique
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  stripeSubscriptionId String              @unique
  stripePriceId       String
  
  plan                Plan
  status              SubscriptionStatus
  
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelAtPeriodEnd   Boolean              @default(false)
  canceledAt          DateTime?
  
  // Quotas inclus dans l'abonnement
  monthlyQuota        Int
  
  // Métadonnées
  trialEnd            DateTime?
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  
  @@index([userId])
  @@index([stripeSubscriptionId])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
}

model Invoice {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  stripeInvoiceId     String               @unique
  stripePaymentIntentId String?
  
  // Montants (en centimes)
  subscriptionAmount  Int                  // Frais d'abonnement
  usageAmount         Int                  // Frais d'usage additionnel
  taxAmount           Int                  @default(0)
  total               Int
  
  currency            String               @default("eur")
  status              InvoiceStatus
  
  // Période de facturation
  periodStart         DateTime
  periodEnd           DateTime
  
  // Paiement
  paidAt              DateTime?
  dueDate             DateTime?
  
  // PDF
  invoicePdf          String?
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  
  @@index([userId])
  @@index([stripeInvoiceId])
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

// ============================================================================
// 📊 USAGE TRACKING & PAY-PER-USE
// ============================================================================

model UsageRecord {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type                UsageType
  platform            Platform
  
  // Coûts (en centimes)
  aiCost              Int                  // Coût IA réel (OpenAI, Vertex AI, etc.)
  serviceFee          Int                  // Frais de service (notre marge)
  totalCharge         Int                  // Total facturé au client
  
  // Quotas
  withinQuota         Boolean              // Dans les quotas ou pay-per-use
  
  // Métadonnées
  videoId             String?
  carrouselId         String?
  postId              String?
  
  metadata            Json?                // Données supplémentaires
  
  createdAt           DateTime             @default(now())
  
  @@index([userId, createdAt])
  @@index([type, platform])
}

enum UsageType {
  SHORT
  REEL
  CARROUSEL
  POST
  STORY
}

enum Platform {
  YOUTUBE
  TIKTOK
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  TWITTER
}

// ============================================================================
// 🔗 SOCIAL MEDIA ACCOUNTS
// ============================================================================

model SocialAccount {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  platform            Platform
  platformUserId      String               // ID sur la plateforme
  username            String
  displayName         String?
  avatar              String?
  followerCount       Int?
  
  // OAuth tokens (chiffrés en production)
  accessToken         String               @db.Text
  refreshToken        String?              @db.Text
  tokenExpiry         DateTime?
  
  // Scopes autorisés
  scopes              String[]
  
  // Status
  isActive            Boolean              @default(true)
  lastSync            DateTime?
  syncError           String?
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  
  @@unique([userId, platform])
  @@index([userId])
  @@index([platform, platformUserId])
}

// ============================================================================
// 🎬 CONTENT GENERATION
// ============================================================================

model Video {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  platform            Platform
  socialAccountId     String?
  
  // Contenu
  title               String
  description         String               @db.Text
  script              Json                 // Script complet (hook, body, cta, etc.)
  hashtags            String[]
  keywords            String[]
  
  // Fichiers
  videoUrl            String?              // URL locale ou S3
  thumbnailUrl        String?
  audioUrl            String?
  
  // Upload
  platformVideoId     String?              // ID sur YouTube/TikTok
  uploadStatus        UploadStatus
  uploadError         String?
  
  // Analytics
  views               Int                  @default(0)
  likes               Int                  @default(0)
  comments            Int                  @default(0)
  shares              Int                  @default(0)
  watchTime           Int                  @default(0) // en secondes
  
  // Coûts
  aiCost              Int                  // en centimes
  serviceFee          Int                  // en centimes
  
  // Planification
  scheduledFor        DateTime?
  publishedAt         DateTime?
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  
  @@index([userId, createdAt])
  @@index([platform, uploadStatus])
}

model Carrousel {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  platform            Platform             // Instagram, LinkedIn
  socialAccountId     String?
  
  // Contenu
  title               String
  caption             String               @db.Text
  slides              Json                 // Array de slides avec images + texte
  hashtags            String[]
  
  // Images
  imageUrls           String[]
  
  // Upload
  platformPostId      String?
  uploadStatus        UploadStatus
  uploadError         String?
  
  // Analytics
  likes               Int                  @default(0)
  comments            Int                  @default(0)
  shares              Int                  @default(0)
  saves               Int                  @default(0)
  
  // Coûts
  aiCost              Int                  // en centimes
  serviceFee          Int                  // en centimes
  
  // Planification
  scheduledFor        DateTime?
  publishedAt         DateTime?
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  
  @@index([userId, createdAt])
  @@index([platform, uploadStatus])
}

model Post {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  platform            Platform
  socialAccountId     String?
  
  // Contenu
  content             String               @db.Text
  mediaUrls           String[]
  hashtags            String[]
  
  // Upload
  platformPostId      String?
  uploadStatus        UploadStatus
  uploadError         String?
  
  // Analytics
  likes               Int                  @default(0)
  comments            Int                  @default(0)
  shares              Int                  @default(0)
  
  // Coûts
  aiCost              Int
  serviceFee          Int
  
  // Planification
  scheduledFor        DateTime?
  publishedAt         DateTime?
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  
  @@index([userId, createdAt])
  @@index([platform, uploadStatus])
}

enum UploadStatus {
  GENERATING
  READY
  UPLOADING
  PUBLISHED
  FAILED
  SCHEDULED
}

// ============================================================================
// 🔑 API KEYS & WEBHOOKS
// ============================================================================

model ApiKey {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name                String               // Nom descriptif
  key                 String               @unique // La clé API (hachée)
  
  // Permissions
  scopes              String[]
  rateLimit           Int                  @default(100) // requêtes/heure
  
  // Usage
  lastUsed            DateTime?
  usageCount          Int                  @default(0)
  
  isActive            Boolean              @default(true)
  expiresAt           DateTime?
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  
  @@index([userId])
  @@index([key])
}

model WebhookLog {
  id                  String               @id @default(cuid())
  
  source              String               // stripe, youtube, tiktok, etc.
  eventType           String
  payload             Json
  
  processed           Boolean              @default(false)
  processedAt         DateTime?
  error               String?
  
  createdAt           DateTime             @default(now())
  
  @@index([source, eventType])
  @@index([processed, createdAt])
}

// ============================================================================
// 📈 ANALYTICS & METRICS
// ============================================================================

model DailyMetrics {
  id                  String               @id @default(cuid())
  date                DateTime             @db.Date
  
  // Utilisateurs
  activeUsers         Int                  @default(0)
  newUsers            Int                  @default(0)
  churnedUsers        Int                  @default(0)
  
  // Revenus (en centimes)
  subscriptionRevenue Int                  @default(0)
  usageRevenue        Int                  @default(0)
  totalRevenue        Int                  @default(0)
  
  // Coûts (en centimes)
  aiCosts             Int                  @default(0)
  serverCosts         Int                  @default(0)
  totalCosts          Int                  @default(0)
  
  // Usage
  videosGenerated     Int                  @default(0)
  carrouselsGenerated Int                  @default(0)
  postsGenerated      Int                  @default(0)
  
  createdAt           DateTime             @default(now())
  
  @@unique([date])
  @@index([date])
}

// ============================================================================
// 🎨 BRAND & PREFERENCES
// ============================================================================

model BrandProfile {
  id                  String               @id @default(cuid())
  userId              String
  
  name                String
  logoUrl             String?
  primaryColor        String?
  secondaryColor      String?
  fontFamily          String?
  
  // Tone & Voice
  tone                String?              // casual, professional, energetic
  vocabulary          Json?                // Mots-clés spécifiques
  
  // Templates
  videoStyle          String?
  thumbnailStyle      String?
  
  isDefault           Boolean              @default(false)
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  
  @@index([userId])
}

// ============================================================================
// 🔔 NOTIFICATIONS & ALERTS
// ============================================================================

model Notification {
  id                  String               @id @default(cuid())
  userId              String
  
  type                NotificationType
  title               String
  message             String               @db.Text
  link                String?
  
  read                Boolean              @default(false)
  readAt              DateTime?
  
  createdAt           DateTime             @default(now())
  
  @@index([userId, read, createdAt])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  QUOTA_WARNING
  QUOTA_EXCEEDED
  PAYMENT_FAILED
  VIDEO_READY
  VIDEO_PUBLISHED
  SUBSCRIPTION_RENEWED
}


