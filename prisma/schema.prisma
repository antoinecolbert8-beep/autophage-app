// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// CORE MODELS
// ==========================================

model Organization {
  id            String @id @default(cuid())
  name          String
  domain        String @unique
  tier          String @default("starter") // starter, pro, enterprise
  mrr           Float  @default(0) // Monthly Recurring Revenue
  creditBalance Int    @default(0) // Available credits for usage
  status        String @default("active") // active, suspended, cancelled

  // Relations
  users           User[]
  projects        Project[]
  integrations    Integration[]
  analytics       AnalyticsSnapshot[]
  leads           Lead[]
  campaigns       Campaign[]
  usageLogs       UsageLog[]
  creditPurchases CreditPurchase[]
  paymentDisputes PaymentDispute[]
  auditLogs       AuditLog[]
  aiActionLogs    AIActionLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🛡️ SECURITY: One-to-one relation with WarChest
  warChest  WarChest?
  // 🤖 AI: Per-tenant isolated AI profile (RGPD compliant)
  aiProfile AIProfile?

  // Marketplace
  marketplaceListings MarketplaceListing[]

  @@index([domain])
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  role     String  @default("member") // admin, member, viewer
  avatar   String?
  password String? // Hashed password for admin/credentials login

  // Subscription & Quota fields
  currentPlan      String   @default("free") // free, pro, enterprise
  stripeCustomerId String?
  usedQuota        Int      @default(0)
  monthlyQuota     Int      @default(10)
  quotaResetDate   DateTime @default(now())

  // Spore Protocol (Referral)
  referralCode String? @unique
  referredBy   String?
  referralTier Int     @default(0) // Current unlocked tier (0=none, 1,3,5,10,25)

  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  saveAttempts   SaveAttempt[]

  // Relations
  subscription   Subscription?
  videos         Video[]
  usageRecords   UsageRecord[]
  posts          Post[]
  brandProfile   BrandProfile?
  userPreference UserPreference?
  auditLogs      AuditLog[]

  // 🛡️ SECURITY: Explicit relation for action history
  actionHistory ActionHistory[]

  // 🚀 Viral Engine: Referral relations
  referralsGiven      Referral[]               @relation("ReferralsGiven")
  referralReceived    Referral?                @relation("ReferralReceived")
  // Models inverses
  marketplaceListings MarketplaceListing[]
  buyerTransactions   MarketplaceTransaction[] @relation("BuyerTransactions")
  sellerTransactions  MarketplaceTransaction[] @relation("SellerTransactions")

  listingsOffered Listing[]     @relation("ListingsOffered")
  contractsBought Contract[]    @relation("ContractsBought")
  contractsSold   Contract[]    @relation("ContractsSold")
  transactions    Transaction[] @relation("UserTransactions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([referralCode])
}

model Project {
  id          String  @id @default(cuid())
  name        String
  domain      String
  description String?
  status      String  @default("active")

  // SEO Data
  keywords KeywordOpportunity[]
  content  ContentAsset[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// ==========================================
// SEO MODULE (APEX)
// ==========================================

model KeywordOpportunity {
  id         String @id @default(cuid())
  keyword    String
  volume     Int // search volume per month
  difficulty Float // 0-100
  intent     String // commercial, informational, navigational, transactional
  cluster    String // topic cluster name
  priority   Float  @default(0) // calculated priority score
  status     String @default("pending") // pending, in-progress, published

  suggestedContent String?
  rankingPosition  Int?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, status])
  @@index([priority])
}

model ContentAsset {
  id              String  @id @default(cuid())
  title           String
  content         String
  slug            String
  metaTitle       String?
  metaDescription String?

  // SEO Metrics
  keywords      String // targeted keywords (CSV)
  semanticScore Float  @default(0) // semantic density score
  wordCount     Int    @default(0)

  // Performance Data
  rankingData String? // String // Json    // {keyword: position, impressions, clicks}
  publishedAt DateTime?
  lastUpdated DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([publishedAt])
}

// ==========================================
// MARKETING MODULE (PULSE)
// ==========================================

model Lead {
  id      String  @id @default(cuid())
  email   String
  name    String?
  company String?
  phone   String?

  // Scoring
  score          Float   @default(0)
  scoreBreakdown String // Json     // {demographic: X, behavioral: Y, engagement: Z, intent: W}
  metadata       String? // String // Json    // Additional info (Sales Nav URL, etc)
  persona        String? // matched persona type
  stage          String  @default("cold") // cold, warm, hot, customer

  // Engagement
  touchpoints Touchpoint[]
  conversions Conversion[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🛡️ SECURITY: Flag to indicate if PII is encrypted (GDPR/Shield Mode)
  isEncrypted Boolean @default(false)

  @@unique([email, organizationId])
  @@index([organizationId, stage])
  @@index([score])
  @@index([createdAt])
}

model Campaign {
  id            String  @id @default(cuid())
  name          String
  type          String // email, sms, social, push
  targetPersona String?

  // Configuration
  messageTemplate String // Json     // template with variables
  triggers        String // Json     // automation triggers
  schedule        String? // String // Json    // scheduling config

  // Performance
  kpis   String // Json     // {sent: X, opened: Y, clicked: Z, converted: W}
  active Boolean @default(true)

  touchpoints Touchpoint[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, active])
}

model Touchpoint {
  id       String  @id @default(cuid())
  type     String // email, sms, call, meeting
  channel  String
  message  String?
  response String?

  // Engagement metrics
  delivered Boolean @default(false)
  opened    Boolean @default(false)
  clicked   Boolean @default(false)
  converted Boolean @default(false)

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([campaignId])
}

model Conversion {
  id       String  @id @default(cuid())
  type     String // signup, purchase, upgrade, referral
  value    Float // monetary value
  source   String // campaign, organic, referral
  metadata String? // String // Json

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([type])
}

// ==========================================
// ANALYTICS & INTEGRATION
// ==========================================

model Integration {
  id          String @id @default(cuid())
  provider    String // google-analytics, stripe, instagram, sendgrid
  credentials String // encrypted JSON
  config      String // Json     // provider-specific config
  status      String @default("active") // active, inactive, error

  lastSync      DateTime?
  syncFrequency Int       @default(60) // minutes

  // ⚡ ARCHITECTURE ZÉRO MAINTENANCE: OAuth Rotation
  refreshToken   String? // Encrypted via Fortress
  tokenExpiresAt DateTime?
  requiresReauth Boolean   @default(false)

  dataPoints DataPoint[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, provider])
}

model DataPoint {
  id         String   @id @default(cuid())
  metric     String // pageviews, conversions, revenue, etc.
  value      Float
  dimensions String // Json     // additional context
  timestamp  DateTime

  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, metric, timestamp])
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  period    String // daily, weekly, monthly
  metrics   String // Json     // aggregated metrics
  timestamp DateTime

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, period, timestamp])
}

// ==========================================
// AI & PREDICTION
// ==========================================

model PredictiveModel {
  id           String @id @default(cuid())
  modelType    String // revenue_forecast, churn_risk, lead_scoring
  version      String
  accuracy     Float
  trainingData String // Json     // metadata about training
  modelPath    String // path to model file or Vertex AI endpoint

  predictions Prediction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([modelType, version])
}

model Prediction {
  id             String  @id @default(cuid())
  entityType     String // lead, organization, campaign
  entityId       String
  predictionType String // score, forecast, classification
  value          Float
  confidence     Float
  metadata       String? // String // Json

  modelId String
  model   PredictiveModel @relation(fields: [modelId], references: [id])

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([modelId])
}

// ==========================================
// BILLING & USAGE
// ==========================================

model UsageLog {
  id          String   @id @default(cuid())
  actionType  String // APEX_GENERATION, SNAP_DISTRIBUTION, etc.
  creditsUsed Int
  metadata    String? // String // Json
  timestamp   DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, timestamp])
  @@index([actionType])
}

model CreditPurchase {
  id              String   @id @default(cuid())
  credits         Int
  amountPaid      Float?
  paymentIntentId String?  @unique // Unique for idempotency — prevents double credit grants
  timestamp       DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([paymentIntentId])
}

model AIActionLog {
  id                String    @id @default(cuid())
  actionType        String // content_generation, lead_scoring, social_distribution, etc.
  entityType        String // keyword, lead, content
  entityId          String
  status            String    @default("pending") // pending, completed, failed
  decisionReasoning String? // String // Json
  executedAt        DateTime?

  // 🔒 RGPD: Multi-tenant isolation — every AI log is scoped to an org
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([actionType, status])
  @@index([entityId])
  @@index([organizationId])
}

// ==========================================
// BRAND & USER PREFERENCES
// ==========================================

model BrandProfile {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceUrl      String
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  fontFamily     String?
  keywords       String // Comma separated
  rawMeta        String? // String // Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model UserPreference {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  fontFamily     String?
  theme          String  @default("dark")
  language       String  @default("fr")

  // 🛡️ GDPR: Privacy Choices
  gdpr_consent     Boolean @default(false)
  ai_data_usage    Boolean @default(true)
  marketing_emails Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// FINANCIAL MODELS
// ==========================================

model WarChest {
  id                     String @id @default(cuid())
  available_budget_cents Int    @default(0) // Budget in cents
  total_spent_cents      Int    @default(0) // Total spent in cents
  reserved_cents         Int    @default(0) // Reserved for pending ops
  currency               String @default("EUR")

  organizationId String?       @unique
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // God Mode Extensions
  holdco_balance_cents           Int    @default(0) // Le Sanctuaire
  opco_status                    String @default("active") // active, draining, frozen
  reinvestment_rate_basis_points Int?   @default(4000)
}

model GhostProfile {
  id          String  @id @default(cuid())
  username    String
  password    String // Encrypted
  platform    String // LINKEDIN, INSTAGRAM, TWITTER, REDDIT
  proxy       String? // ip:port:user:pass
  cookies     String?
  userAgent   String?
  fingerprint String? // String // Json    // JA3/Canvas hashes

  status          String   @default("active") // active, burned, warming
  reputationScore Float    @default(0.5)
  lastActive      DateTime @default(now())

  interactions GhostInteraction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([platform, status])
}

model GhostInteraction {
  id      String       @id @default(cuid())
  ghostId String
  ghost   GhostProfile @relation(fields: [ghostId], references: [id], onDelete: Cascade)

  targetId   String // Post ID, User ID, Comment ID
  actionType String // LIKE, COMMENT, SHARE, VOTE_UP, SAVE
  content    String?

  performedAt DateTime @default(now())
  status      String   @default("completed")

  @@index([targetId])
  @@index([performedAt])
}

model PaymentDispute {
  id              String @id @default(cuid())
  stripeDisputeId String @unique
  amount          Float
  currency        String @default("EUR")
  reason          String
  status          String // warning_needs_response, won, lost, under_review

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([organizationId, status])
}

model ActionHistory {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform String // linkedin, instagram, email, etc.
  action   String // post, comment, like, send, etc.
  targetId String? // ID of target entity
  context  String? // String // Json    // Additional context data
  status   String  @default("completed")

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([platform])
  @@index([createdAt])
}

model ContentStat {
  id       String @id @default(cuid())
  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform String // linkedin, instagram, twitter, etc.
  views    Int    @default(0)
  likes    Int    @default(0)
  comments Int    @default(0)
  shares   Int    @default(0)
  saves    Int    @default(0)
  clicks   Int    @default(0)

  collectedAt DateTime @default(now())

  @@index([postId])
  @@index([platform])
  @@index([collectedAt])
}

model Post {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          String // linkedin, instagram, twitter, tiktok, youtube, etc.
  content           String
  mediaUrl          String?
  externalId        String? // ID from the platform
  status            String    @default("draft") // draft, scheduled, published, failed
  performance_score Float     @default(0)
  scheduledAt       DateTime?
  publishedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stats ContentStat[]

  @@index([userId])
  @@index([platform])
  @@index([status])
  @@index([publishedAt])
}

// ==========================================
// VIDEO & SUBSCRIPTION MODELS
// ==========================================

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeSubscriptionId String?
  status               String    @default("active") // active, canceled, past_due, paused
  plan                 String    @default("free") // free, pro, enterprise
  periodStart          DateTime?
  periodEnd            DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model Video {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform        String // YOUTUBE, TIKTOK, INSTAGRAM
  title           String
  description     String?
  script          String? // String // Json
  hashtags        String // Comma separated
  keywords        String // Comma separated
  videoUrl        String?
  thumbnailUrl    String?
  platformVideoId String?
  uploadStatus    String  @default("PENDING") // PENDING, PUBLISHED, FAILED

  aiCost     Float @default(0)
  serviceFee Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usageRecords UsageRecord[]

  @@index([userId])
  @@index([platform])
  @@index([uploadStatus])
}

model UsageRecord {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String // SHORT, POST, CALL, AI_QUERY
  platform    String?
  aiCost      Float   @default(0)
  serviceFee  Float   @default(0)
  totalCharge Float   @default(0)
  withinQuota Boolean @default(true)

  videoId String?
  video   Video?  @relation(fields: [videoId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ==========================================
// LEGACY MODULES (RESTORED)
// ==========================================

// Enum removed for SQLite compatibility
// REVENUE_IN, TAX_RESERVE, AD_SPEND_OUT

model TreasuryLedger {
  id                String  @id @default(cuid())
  amount_cents      Int
  type              String // LedgerType
  referenceId       String
  resulting_balance Int
  stripeCustomerId  String?

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([createdAt])
}

model PerformanceMetric {
  id          String @id @default(cuid())
  postId      String
  spend       Int
  impressions Int
  clicks      Int
  ctr         Float
  roas        Float

  createdAt DateTime @default(now())

  @@index([postId])
}

model SaveAttempt {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trigger   String
  offerSent String
  status    String @default("PENDING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AuditLog {
  id             String        @id @default(cuid())
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  action     String // e.g., "USER_LOGIN", "POST_CREATED", "BILLING_UPDATE"
  entityType String // e.g., "USER", "POST", "SUBSCRIPTION"
  entityId   String?
  details    String? // JSON stringified details
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([action])
}

// ==========================================
// VIRAL ENGINE — PARRAINAGE & LEADERBOARD
// ==========================================

// Parrainage direct 1-niveau (non-MLM, conforme loi française)
model Referral {
  id         String @id @default(cuid())
  referrerId String
  referrer   User   @relation("ReferralsGiven", fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId  String @unique // Un utilisateur ne peut avoir qu'un seul parrain
  referee    User   @relation("ReferralReceived", fields: [refereeId], references: [id], onDelete: Cascade)

  // active = filleul a effectué au moins 1 post payant dans les 30 derniers jours
  status     String    @default("pending") // pending, escrow, active, churned, fraudulent
  rewardTier Int? // Palier atteint par le parrain lors de l'activation (1,3,5,10,25)
  rewardedAt DateTime?

  // 🛡️ VERROU DE RENTABILITÉ (Anti-Sybil)
  trustScore            Float     @default(1.0) // Chute si card_type = prepaid/gift
  escrowEndsAt          DateTime? // Période de séquestre (14 jours)
  refereeLTV            Float     @default(0) // Valeur vie du filleul (doit dépasser coût God Mode)
  isProfitabilityLocked Boolean   @default(true) // Débloqué uniquement quand Σ LTV > Coût

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerId])
  @@index([status])
}

// Snapshot hebdomadaire/mensuel du classement — généré par cron
model LeaderboardSnapshot {
  id     String @id @default(cuid())
  period String // ISO: "2026-W09" ou "2026-02"

  // Sérialisé en JSON (top 10 chaque)
  topPublishers String // [{userId, name, avatar, postCount, totalEngagement}]
  topReferrers  String // [{userId, name, avatar, activeReferrals, tier}]

  generatedAt DateTime @default(now())

  @@unique([period])
  @@index([period])
}

// ==========================================
// AI PROFILING — ISOLATION PAR TENANT (RGPD)
// ==========================================

// Profil IA isolé par organisation — alimenté par le ai-profile-worker
model AIProfile {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Préférences apprises par publish performance
  bestPostTimes String @default("[]") // JSON: {"LINKEDIN":["09:00","18:00"]}
  topHashtags   String @default("[]") // JSON: ["#SaaS","#IA"]
  contentStyle  String @default("educational") // Inféré: educational, storytelling, controversy
  avgEngagement Float  @default(0)
  publishCount  Int    @default(0)
  successRate   Float  @default(0) // Ratio posts succeeded / total

  // RGPD
  consentGiven Boolean   @default(false)
  anonymizedAt DateTime?

  // Sovereign Score / Ledger de Réputation
  reputationScore Float @default(100) // Initial trust score, max 100, drops on disputes, climbs on success

  // Fiscalité & Compliance
  vatNumber    String?   // Obligatoire pour Reverse Charge B2B en UE
  countryCode  String?   @default("FR") // ISO Pays (ex: FR, US, DE)

  // ⚡ GOD MODE: Autonomous feature toggle states (JSON)
  godModeConfig String? // JSON: {"selfPromotion":true,"linkedinBot":false,...}

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([organizationId])
}

model MarketplaceListing {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Listing Data
  title       String
  description String
  type        String // "SERVICE", "DIGITAL_ASSET", "PHYSICAL_ASSET"
  priceCent   Int // Amount in smallest currency unit
  currency    String @default("EUR")
  status      String @default("ACTIVE") // ACTIVE, PAUSED, SOLD, DELISTED

  // IA Targeting & Matching (Global Vector Indexing)
  category        String
  tags            String // JSON: ["AI", "Consulting", "Automation"]
  vectorId        String? // Reference to Pinecone/PGVector embedding ID
  targetLanguages String  @default("[\"EN\", \"FR\"]") // JSON array of languages

  // Location / Global reach
  isGlobal  Boolean @default(true)
  latitude  Float? // For local marketplace features (LeCoin 2.0)
  longitude Float?
  city      String?
  country   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions MarketplaceTransaction[]

  @@index([organizationId])
  @@index([category])
  @@index([status])
  @@index([latitude, longitude]) // Geo-spatial queries
}

model MarketplaceTransaction {
  id        String             @id @default(cuid())
  listingId String
  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Restrict)

  buyerId  String
  buyer    User   @relation("BuyerTransactions", fields: [buyerId], references: [id])
  sellerId String
  seller   User   @relation("SellerTransactions", fields: [sellerId], references: [id])

  // Financials & Escrow (Stripe Connect)
  amountCent            Int
  currency              String
  stripePaymentIntentId String? @unique
  stripeTransferId      String? @unique

  status String @default("ESCROW_PENDING") // ESCROW_PENDING, ESCROW_HELD, COMPLETED, DISPUTED, REFUNDED

  // IA Negotiation / Conversation
  conversationId String? // ID to link to the AI negotiation chain

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

// ==========================================
// PILIER 6 : ELA GLOBAL MARKET & OUTSOURCING
// ==========================================

model Listing {
  id       String @id @default(cuid())
  sellerId String
  seller   User   @relation("ListingsOffered", fields: [sellerId], references: [id])

  title       String
  description String // Note: @db.Text n'est pas supporté par SQLite standard, donc retiré.
  priceAmount Float
  currency    String @default("EUR")
  category    String // ex: "CONTENT_CREATION", "LEAD_GEN", "DESIGN"

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts Contract[]
}

model Contract {
  id       String @id @default(cuid())
  buyerId  String
  buyer    User   @relation("ContractsBought", fields: [buyerId], references: [id])
  sellerId String
  seller   User   @relation("ContractsSold", fields: [sellerId], references: [id])

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id])

  // L'IA agit comme Tiers de Confiance
  status      String @default("PENDING_ESCROW") // PENDING_ESCROW, IN_PROGRESS, IN_REVIEW, COMPLETED, DISPUTED, CANCELLED
  totalAmount Float
  currency    String @default("EUR")
  platformFee Float // Commission souveraine d'ELA (ex: 10%)

  aiPrompt String? // Les instructions générées par l'IA pour encadrer le prestataire

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  milestones   Milestone[]
  transactions Transaction[]
}

model Milestone {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  title       String
  description String
  amount      Float
  status      String @default("PENDING") // PENDING, SUBMITTED, AI_VERIFIED, PAID

  proofOfWorkUrl    String? // Lien vers le livrable (URL du post, document, image)
  aiValidationScore Float? // Score de 0 à 100 donné par l'IA d'ELA. Si > 80, l'argent est libéré.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])
  userId     String
  user       User     @relation("UserTransactions", fields: [userId], references: [id])

  stripeChargeId   String? @unique // Preuve d'encaissement
  stripeTransferId String? @unique // Preuve de reversement au sous-traitant

  type     String // ESCROW_DEPOSIT, ESCROW_RELEASE, PLATFORM_FEE, REFUND
  amount   Float
  currency String @default("EUR")
  status   String @default("PROCESSING") // PROCESSING, SUCCEEDED, FAILED

  createdAt DateTime @default(now())

  accountingRecord AccountingRecord?
}

// ==========================================
// AUTOMATISATION COMPTABLE & FISCALE
// ==========================================

model AccountingRecord {
  id              String   @id @default(cuid())
  transactionId   String   @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id])
  
  invoiceUrl      String   // Lien vers le PDF généré (LegalPlace/S3)
  documentType    String   // FACTURE_VENTE, FACTURE_ACHAT, COMMISSION
  
  taxAmount       Float    // Calcul automatique de la TVA
  netAmount       Float    // Ce qui reste dans la poche d'ELA
  
  aiNote          String   // La note créée par l'IA pour le comptable
  isSyncedToSheets Boolean @default(false)
  
  createdAt       DateTime @default(now())
}
