generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                  String               @id @default(cuid())
  name                String
  domain              String               @unique
  tier                String               @default("starter")
  mrr                 Float                @default(0)
  creditBalance       Int                  @default(0)
  status              String               @default("active")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  aiActionLogs        AIActionLog[]
  aiProfile           AIProfile?
  analytics           AnalyticsSnapshot[]
  auditLogs           AuditLog[]
  campaigns           Campaign[]
  creditPurchases     CreditPurchase[]
  integrations        Integration[]
  leads               Lead[]
  marketplaceListings MarketplaceListing[]
  paymentDisputes     PaymentDispute[]
  projects            Project[]
  usageLogs           UsageLog[]
  users               User[]
  warChest            WarChest?

  @@index([domain])
}

model User {
  id                  String                   @id @default(cuid())
  email               String                   @unique
  name                String?
  role                String                   @default("member")
  avatar              String?
  password            String?
  currentPlan         String                   @default("free")
  stripeCustomerId    String?
  usedQuota           Int                      @default(0)
  monthlyQuota        Int                      @default(10)
  quotaResetDate      DateTime                 @default(now())
  referralCode        String?                  @unique
  referredBy          String?
  referralTier        Int                      @default(0)
  organizationId      String
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  aqciScore           Float                    @default(0)
  coalitionId         String?
  level               Int                      @default(1)
  xp                  Int                      @default(0)
  actionHistory       ActionHistory[]
  auditLogs           AuditLog[]
  brandProfile        BrandProfile?
  contractsBought     Contract[]               @relation("ContractsBought")
  contractsSold       Contract[]               @relation("ContractsSold")
  listingsOffered     Listing[]                @relation("ListingsOffered")
  marketplaceListings MarketplaceListing[]
  buyerTransactions   MarketplaceTransaction[] @relation("BuyerTransactions")
  sellerTransactions  MarketplaceTransaction[] @relation("SellerTransactions")
  posts               Post[]
  referralReceived    Referral?                @relation("ReferralReceived")
  referralsGiven      Referral[]               @relation("ReferralsGiven")
  saveAttempts        SaveAttempt[]
  subscription        Subscription?
  transactions        Transaction[]            @relation("UserTransactions")
  usageRecords        UsageRecord[]
  coalition           Coalition?               @relation(fields: [coalitionId], references: [id])
  organization        Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userPreference      UserPreference?
  quests              UserQuest[]
  videos              Video[]

  @@index([organizationId])
  @@index([referralCode])
}

model Project {
  id             String               @id @default(cuid())
  name           String
  domain         String
  description    String?
  status         String               @default("active")
  organizationId String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  content        ContentAsset[]
  keywords       KeywordOpportunity[]
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model KeywordOpportunity {
  id               String   @id @default(cuid())
  keyword          String
  volume           Int
  difficulty       Float
  intent           String
  cluster          String
  priority         Float    @default(0)
  status           String   @default("pending")
  suggestedContent String?
  rankingPosition  Int?
  projectId        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([priority])
}

model ContentAsset {
  id              String    @id @default(cuid())
  title           String
  content         String
  slug            String
  metaTitle       String?
  metaDescription String?
  keywords        String
  semanticScore   Float     @default(0)
  wordCount       Int       @default(0)
  rankingData     String?
  publishedAt     DateTime?
  lastUpdated     DateTime?
  projectId       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([publishedAt])
}

model Lead {
  id             String       @id @default(cuid())
  email          String
  name           String?
  company        String?
  phone          String?
  score          Float        @default(0)
  scoreBreakdown String
  metadata       String?
  persona        String?
  stage          String       @default("cold")
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  isEncrypted    Boolean      @default(false)
  conversions    Conversion[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  touchpoints    Touchpoint[]

  @@unique([email, organizationId])
  @@index([organizationId, stage])
  @@index([score])
  @@index([createdAt])
}

model Campaign {
  id              String       @id @default(cuid())
  name            String
  type            String
  targetPersona   String?
  messageTemplate String
  triggers        String
  schedule        String?
  kpis            String
  active          Boolean      @default(true)
  organizationId  String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  touchpoints     Touchpoint[]

  @@index([organizationId, active])
}

model Touchpoint {
  id         String    @id @default(cuid())
  type       String
  channel    String
  message    String?
  response   String?
  delivered  Boolean   @default(false)
  opened     Boolean   @default(false)
  clicked    Boolean   @default(false)
  converted  Boolean   @default(false)
  leadId     String
  campaignId String?
  createdAt  DateTime  @default(now())
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  lead       Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([campaignId])
}

model Conversion {
  id        String   @id @default(cuid())
  type      String
  value     Float
  source    String
  metadata  String?
  leadId    String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([type])
}

model Integration {
  id             String       @id @default(cuid())
  provider       String
  credentials    String
  config         String
  status         String       @default("active")
  lastSync       DateTime?
  syncFrequency  Int          @default(60)
  refreshToken   String?
  tokenExpiresAt DateTime?
  requiresReauth Boolean      @default(false)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  dataPoints     DataPoint[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, provider])
}

model DataPoint {
  id            String      @id @default(cuid())
  metric        String
  value         Float
  dimensions    String
  timestamp     DateTime
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, metric, timestamp])
}

model AnalyticsSnapshot {
  id             String       @id @default(cuid())
  period         String
  metrics        String
  timestamp      DateTime
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, period, timestamp])
}

model PredictiveModel {
  id           String       @id @default(cuid())
  modelType    String
  version      String
  accuracy     Float
  trainingData String
  modelPath    String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  predictions  Prediction[]

  @@index([modelType, version])
}

model Prediction {
  id             String          @id @default(cuid())
  entityType     String
  entityId       String
  predictionType String
  value          Float
  confidence     Float
  metadata       String?
  modelId        String
  createdAt      DateTime        @default(now())
  model          PredictiveModel @relation(fields: [modelId], references: [id])

  @@index([entityType, entityId])
  @@index([modelId])
}

model UsageLog {
  id             String       @id @default(cuid())
  actionType     String
  creditsUsed    Int
  metadata       String?
  timestamp      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, timestamp])
  @@index([actionType])
}

model CreditPurchase {
  id              String       @id @default(cuid())
  credits         Int
  amountPaid      Float?
  paymentIntentId String?      @unique
  timestamp       DateTime     @default(now())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([paymentIntentId])
}

model AIActionLog {
  id                String        @id @default(cuid())
  actionType        String
  entityType        String
  entityId          String
  status            String        @default("pending")
  decisionReasoning String?
  executedAt        DateTime?
  organizationId    String?
  createdAt         DateTime      @default(now())
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([actionType, status])
  @@index([entityId])
  @@index([organizationId])
}

model BrandProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  sourceUrl      String
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  fontFamily     String?
  keywords       String
  rawMeta        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  logoUrl          String?
  primaryColor     String?
  secondaryColor   String?
  fontFamily       String?
  theme            String   @default("dark")
  language         String   @default("fr")
  gdpr_consent     Boolean  @default(false)
  ai_data_usage    Boolean  @default(true)
  marketing_emails Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WarChest {
  id                             String        @id @default(cuid())
  available_budget_cents         Int           @default(0)
  total_spent_cents              Int           @default(0)
  reserved_cents                 Int           @default(0)
  currency                       String        @default("EUR")
  organizationId                 String?       @unique
  createdAt                      DateTime      @default(now())
  updatedAt                      DateTime      @updatedAt
  holdco_balance_cents           Int           @default(0)
  opco_status                    String        @default("active")
  reinvestment_rate_basis_points Int?          @default(4000)
  organization                   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model GhostProfile {
  id              String             @id @default(cuid())
  username        String
  password        String
  platform        String
  proxy           String?
  cookies         String?
  userAgent       String?
  fingerprint     String?
  status          String             @default("active")
  reputationScore Float              @default(0.5)
  lastActive      DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  interactions    GhostInteraction[]

  @@index([platform, status])
}

model GhostInteraction {
  id          String       @id @default(cuid())
  ghostId     String
  targetId    String
  actionType  String
  content     String?
  performedAt DateTime     @default(now())
  status      String       @default("completed")
  ghost       GhostProfile @relation(fields: [ghostId], references: [id], onDelete: Cascade)

  @@index([targetId])
  @@index([performedAt])
}

model PaymentDispute {
  id              String       @id @default(cuid())
  stripeDisputeId String       @unique
  amount          Float
  currency        String       @default("EUR")
  reason          String
  status          String
  organizationId  String
  createdAt       DateTime     @default(now())
  resolvedAt      DateTime?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

model ActionHistory {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  action    String
  targetId  String?
  context   String?
  status    String   @default("completed")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@index([createdAt])
}

model ContentStat {
  id          String   @id @default(cuid())
  postId      String
  platform    String
  views       Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  saves       Int      @default(0)
  clicks      Int      @default(0)
  collectedAt DateTime @default(now())
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([platform])
  @@index([collectedAt])
}

model Post {
  id                String        @id @default(cuid())
  userId            String
  platform          String
  content           String
  mediaUrl          String?
  externalId        String?
  status            String        @default("draft")
  performance_score Float         @default(0)
  scheduledAt       DateTime?
  publishedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  stats             ContentStat[]
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@index([status])
  @@index([publishedAt])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeSubscriptionId String?
  status               String    @default("active")
  plan                 String    @default("free")
  periodStart          DateTime?
  periodEnd            DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Video {
  id              String        @id @default(cuid())
  userId          String
  platform        String
  title           String
  description     String?
  script          String?
  hashtags        String
  keywords        String
  videoUrl        String?
  thumbnailUrl    String?
  platformVideoId String?
  uploadStatus    String        @default("PENDING")
  aiCost          Float         @default(0)
  serviceFee      Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  usageRecords    UsageRecord[]
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@index([uploadStatus])
}

model UsageRecord {
  id          String   @id @default(cuid())
  userId      String
  type        String
  platform    String?
  aiCost      Float    @default(0)
  serviceFee  Float    @default(0)
  totalCharge Float    @default(0)
  withinQuota Boolean  @default(true)
  videoId     String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video       Video?   @relation(fields: [videoId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model TreasuryLedger {
  id                String   @id @default(cuid())
  amount_cents      Int
  type              String
  referenceId       String
  resulting_balance Int
  stripeCustomerId  String?
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([type])
  @@index([createdAt])
}

model PerformanceMetric {
  id          String   @id @default(cuid())
  postId      String
  spend       Int
  impressions Int
  clicks      Int
  ctr         Float
  roas        Float
  createdAt   DateTime @default(now())

  @@index([postId])
}

model SaveAttempt {
  id        String   @id @default(cuid())
  userId    String
  trigger   String
  offerSent String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id             String        @id @default(cuid())
  userId         String?
  organizationId String?
  action         String
  entityType     String
  entityId       String?
  details        String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([action])
}

model Referral {
  id                    String    @id @default(cuid())
  referrerId            String
  refereeId             String    @unique
  status                String    @default("pending")
  rewardTier            Int?
  rewardedAt            DateTime?
  trustScore            Float     @default(1.0)
  escrowEndsAt          DateTime?
  refereeLTV            Float     @default(0)
  isProfitabilityLocked Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  referee               User      @relation("ReferralReceived", fields: [refereeId], references: [id], onDelete: Cascade)
  referrer              User      @relation("ReferralsGiven", fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([status])
}

model LeaderboardSnapshot {
  id            String   @id @default(cuid())
  period        String   @unique
  topPublishers String
  topReferrers  String
  generatedAt   DateTime @default(now())

  @@index([period])
}

model AIProfile {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  bestPostTimes   String       @default("[]")
  topHashtags     String       @default("[]")
  contentStyle    String       @default("educational")
  avgEngagement   Float        @default(0)
  publishCount    Int          @default(0)
  successRate     Float        @default(0)
  consentGiven    Boolean      @default(false)
  anonymizedAt    DateTime?
  reputationScore Float        @default(100)
  vatNumber       String?
  countryCode     String?      @default("FR")
  godModeConfig   String?
  updatedAt       DateTime     @updatedAt
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model MarketplaceListing {
  id              String                   @id @default(cuid())
  organizationId  String
  userId          String
  title           String
  description     String
  type            String
  priceCent       Int
  currency        String                   @default("EUR")
  status          String                   @default("ACTIVE")
  category        String
  tags            String
  vectorId        String?
  targetLanguages String                   @default("[\"EN\", \"FR\"]")
  isGlobal        Boolean                  @default(true)
  latitude        Float?
  longitude       Float?
  city            String?
  country         String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    MarketplaceTransaction[]

  @@index([organizationId])
  @@index([category])
  @@index([status])
  @@index([latitude, longitude])
}

model MarketplaceTransaction {
  id                    String             @id @default(cuid())
  listingId             String
  buyerId               String
  sellerId              String
  amountCent            Int
  currency              String
  stripePaymentIntentId String?            @unique
  stripeTransferId      String?            @unique
  status                String             @default("ESCROW_PENDING")
  conversationId        String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  buyer                 User               @relation("BuyerTransactions", fields: [buyerId], references: [id])
  listing               MarketplaceListing @relation(fields: [listingId], references: [id])
  seller                User               @relation("SellerTransactions", fields: [sellerId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model Listing {
  id          String     @id @default(cuid())
  sellerId    String
  title       String
  description String
  priceAmount Float
  currency    String     @default("EUR")
  category    String
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  contracts   Contract[]
  seller      User       @relation("ListingsOffered", fields: [sellerId], references: [id])
}

model Contract {
  id           String        @id @default(cuid())
  buyerId      String
  sellerId     String
  listingId    String?
  status       String        @default("PENDING_ESCROW")
  totalAmount  Float
  currency     String        @default("EUR")
  platformFee  Float
  aiPrompt     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  buyer        User          @relation("ContractsBought", fields: [buyerId], references: [id])
  listing      Listing?      @relation(fields: [listingId], references: [id])
  seller       User          @relation("ContractsSold", fields: [sellerId], references: [id])
  milestones   Milestone[]
  transactions Transaction[]
}

model Milestone {
  id                String   @id @default(cuid())
  contractId        String
  title             String
  description       String
  amount            Float
  status            String   @default("PENDING")
  proofOfWorkUrl    String?
  aiValidationScore Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  contract          Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model Transaction {
  id               String            @id @default(cuid())
  contractId       String
  userId           String
  stripeChargeId   String?           @unique
  stripeTransferId String?           @unique
  type             String
  amount           Float
  currency         String            @default("EUR")
  status           String            @default("PROCESSING")
  createdAt        DateTime          @default(now())
  accountingRecord AccountingRecord?
  contract         Contract          @relation(fields: [contractId], references: [id])
  user             User              @relation("UserTransactions", fields: [userId], references: [id])
}

model AccountingRecord {
  id               String      @id @default(cuid())
  transactionId    String      @unique
  invoiceUrl       String
  documentType     String
  taxAmount        Float
  netAmount        Float
  aiNote           String
  isSyncedToSheets Boolean     @default(false)
  createdAt        DateTime    @default(now())
  transaction      Transaction @relation(fields: [transactionId], references: [id])
}

model Coalition {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  logoUrl     String?
  inviteCode  String           @unique
  level       Int              @default(1)
  totalAqci   Float            @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  quests      CoalitionQuest[]
  members     User[]

  @@index([totalAqci])
}

model Quest {
  id              String           @id @default(cuid())
  title           String
  description     String
  type            String           @default("SOLO")
  xpReward        Int              @default(0)
  aqciReward      Float            @default(0)
  creditReward    Int              @default(0)
  triggerEvent    String
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  coalitionQuests CoalitionQuest[]
  userQuests      UserQuest[]
}

model UserQuest {
  id          String    @id @default(cuid())
  userId      String
  questId     String
  status      String    @default("PENDING")
  progress    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questId])
  @@index([status])
}

model CoalitionQuest {
  id          String    @id @default(cuid())
  coalitionId String
  questId     String
  status      String    @default("PENDING")
  progress    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  coalition   Coalition @relation(fields: [coalitionId], references: [id], onDelete: Cascade)
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([coalitionId, questId])
  @@index([status])
}
